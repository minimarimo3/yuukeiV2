{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yuukei",
  "version": "0.1.0",
  "identifier": "jp.minimarimo.yuukei.v2",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "Yuukei Settings",
        "width": 980,
        "height": 720,
        "minWidth": 720,
        "minHeight": 560,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../packs/default-yuukei": "packs/default-yuukei"
    }
  }
}
