{
  "name": "yuukei-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:cli": "cargo build -p yuukei-cli-surface",
    "build:tauri": "pnpm --filter @yuukei/desktop tauri build",
    "dev": "pnpm dev:cli",
    "dev:cli": "cargo run -p yuukei-cli-surface",
    "dev:tauri": "pnpm --filter @yuukei/desktop tauri dev",
    "release": "pnpm build:tauri",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@11.9.0"
}
