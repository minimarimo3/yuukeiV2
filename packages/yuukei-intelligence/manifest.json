{
  "schemaVersion": 1,
  "id": "yuukei-intelligence",
  "displayName": "Yuukei Intelligence",
  "runtime": "process",
  "permissions": {
    "broadEventSubscription": false
  },
  "capabilities": [
    {
      "capability": "dialogue.generate",
      "methods": [
        "generate"
      ]
    },
    {
      "capability": "dialogue.interpret",
      "methods": [
        "interpret"
      ]
    }
  ],
  "process": {
    "command": "node",
    "args": [
      "src/main.mjs"
    ],
    "timeoutMs": 150000
  },
  "config": {
    "provider": "openai-compatible",
    "timeoutMs": 120000,
    "gemini": {
      "model": "gemini-2.5-flash"
    },
    "openaiCompatible": {
      "baseUrl": "http://192.168.0.126:1234/v1",
      "model": "google/gemma-4-26b-a4b",
      "responseFormat": "none"
    }
  },
  "configSchema": {
    "provider": [
      "gemini",
      "openai-compatible"
    ],
    "timeoutMs": "number",
    "gemini": {
      "apiKey": "string",
      "model": "string"
    },
    "openaiCompatible": {
      "baseUrl": "string",
      "apiKey": "string",
      "model": "string",
      "responseFormat": [
        "none",
        "json_schema"
      ]
    }
  }
}
