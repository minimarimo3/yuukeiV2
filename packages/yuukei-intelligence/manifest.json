{
  "schemaVersion": 1,
  "id": "yuukei-intelligence",
  "displayName": "Yuukei Intelligence",
  "runtime": "process",
  "permissions": {
    "broadEventSubscription": false
  },
  "capabilities": [
    {
      "capability": "dialogue.generate",
      "methods": [
        "generate"
      ]
    },
    {
      "capability": "dialogue.interpret",
      "methods": [
        "interpret"
      ]
    },
    {
      "capability": "dialogue.extract",
      "methods": [
        "extract"
      ]
    },
    {
      "capability": "memory.index",
      "methods": [
        "index"
      ]
    },
    {
      "capability": "memory.retrieve",
      "methods": [
        "retrieve"
      ]
    },
    {
      "capability": "mood.evaluate",
      "methods": [
        "evaluate"
      ]
    }
  ],
  "emittedEvents": [
    "ext.yuukei-intelligence.mood.changed"
  ],
  "signalAliases": [
    {
      "alias": "気分_変化",
      "signal": "ext.yuukei-intelligence.mood.changed"
    }
  ],
  "process": {
    "command": "node",
    "args": [
      "src/main.mjs"
    ],
    "timeoutMs": 150000
  },
  "config": {
    "provider": "openai-compatible",
    "timeoutMs": 120000,
    "gemini": {
      "model": "gemini-2.5-flash"
    },
    "openaiCompatible": {
      "baseUrl": "http://192.168.0.126:1234/v1",
      "model": "google/gemma-4-26b-a4b",
      "responseFormat": "none"
    }
  },
  "settings": {
    "fields": [
      {
        "key": "provider",
        "type": "select",
        "label": "プロバイダ",
        "options": [
          {
            "value": "gemini",
            "label": "Gemini"
          },
          {
            "value": "openai-compatible",
            "label": "OpenAI互換 (LM Studio等)"
          }
        ],
        "default": "openai-compatible"
      },
      {
        "key": "timeoutMs",
        "type": "number",
        "label": "タイムアウト(ms)",
        "default": 30000,
        "min": 1000
      },
      {
        "key": "mood.intervalMinutes",
        "type": "number",
        "label": "気分評価の間隔(分)",
        "description": "0分で気分評価を無効にします。",
        "default": 10,
        "min": 0
      },
      {
        "key": "gemini.apiKey",
        "type": "secret",
        "label": "Gemini APIキー",
        "visibleWhen": {
          "key": "provider",
          "equals": "gemini"
        }
      },
      {
        "key": "gemini.model",
        "type": "string",
        "label": "Geminiモデル",
        "default": "gemini-2.5-flash",
        "visibleWhen": {
          "key": "provider",
          "equals": "gemini"
        }
      },
      {
        "key": "openaiCompatible.baseUrl",
        "type": "string",
        "label": "OpenAI互換 Base URL",
        "default": "http://127.0.0.1:1234/v1",
        "visibleWhen": {
          "key": "provider",
          "equals": "openai-compatible"
        }
      },
      {
        "key": "openaiCompatible.apiKey",
        "type": "secret",
        "label": "OpenAI互換 APIキー",
        "visibleWhen": {
          "key": "provider",
          "equals": "openai-compatible"
        }
      },
      {
        "key": "openaiCompatible.model",
        "type": "string",
        "label": "OpenAI互換モデル",
        "default": "local-model",
        "visibleWhen": {
          "key": "provider",
          "equals": "openai-compatible"
        }
      },
      {
        "key": "openaiCompatible.responseFormat",
        "type": "select",
        "label": "レスポンス形式",
        "options": [
          {
            "value": "none",
            "label": "none"
          },
          {
            "value": "json_object",
            "label": "json_object"
          },
          {
            "value": "json_schema",
            "label": "json_schema"
          }
        ],
        "default": "none",
        "visibleWhen": {
          "key": "provider",
          "equals": "openai-compatible"
        }
      }
    ]
  }
}
